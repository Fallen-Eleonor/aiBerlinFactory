GEMINI_API_KEY=your-gemini-api-key
STARTUP_OS_GEMINI_MODEL=gemini-3-flash-preview
GOOGLE_GENAI_API_VERSION=beta
STARTUP_OS_ALLOWED_ORIGINS=http://localhost:3000
# Backward-compatible legacy alias:
# STARTUP_OS_CORS_ORIGINS=http://localhost:3000
# Optional Vertex AI mode instead of API key:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
